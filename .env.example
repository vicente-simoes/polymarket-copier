# Core
NODE_ENV=development
LOG_LEVEL=info

# Web dashboard auth (GitHub OAuth + username allowlist)
AUTH_SECRET=replace-with-long-random-secret
AUTH_GITHUB_ID=replace-me
AUTH_GITHUB_SECRET=replace-me
AUTH_GITHUB_ALLOWED_USERS=your-github-username
# Optional: set the public base URL explicitly in some deployments
# AUTH_URL=http://localhost:3000
# AUTH_TRUST_HOST=true

# Datastores
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/polymarket_copier
WEB_DB_CONNECTION_LIMIT=10
WEB_DB_POOL_TIMEOUT=30
WORKER_DB_CONNECTION_LIMIT=6
WORKER_DB_POOL_TIMEOUT=30
REDIS_URL=redis://localhost:6379
POSTGRES_DB=polymarket_copier
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Polymarket follower credentials (L1 + L2; API creds alone are not enough to sign orders)
# L1 signer (required when EXECUTION_ENGINE_ENABLED=true)
POLYMARKET_FOLLOWER_PRIVATE_KEY=replace-me
POLYMARKET_CHAIN_ID=137
POLYMARKET_SIGNATURE_TYPE=EOA
# Required for POLY_PROXY / POLY_GNOSIS_SAFE signing modes
POLYMARKET_FUNDER_ADDRESS=
# L2 CLOB API credentials (generate/derive via `pnpm polymarket:creds`)
POLYMARKET_API_KEY=replace-me
POLYMARKET_API_SECRET=replace-me
POLYMARKET_PASSPHRASE=replace-me

# Leader detection
ALCHEMY_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/replace-me
DATA_API_BASE_URL=https://data-api.polymarket.com
CLOB_REST_BASE_URL=https://clob.polymarket.com
CLOB_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
CLOB_USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user

# Runtime controls
COPY_SYSTEM_ENABLED=false
TRADE_DETECTION_ENABLED=true
USER_CHANNEL_WS_ENABLED=true
FILL_RECONCILE_ENABLED=true
FILL_RECONCILE_INTERVAL_SECONDS=30
FILL_BACKFILL_DEFAULT_LOOKBACK_DAYS=30
FILL_PARSE_STARVATION_WINDOW_SECONDS=300
FILL_PARSE_STARVATION_MIN_MESSAGES=20
CHAIN_TRIGGER_WS_ENABLED=true
POLYMARKET_EXCHANGE_CONTRACTS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E,0xC5d563A36AE78145C45a50134d48A1215220f80a
CHAIN_TRIGGER_DEDUPE_TTL_SECONDS=86400
CHAIN_TRIGGER_WALLET_REFRESH_INTERVAL_MS=30000
CHAIN_TRIGGER_RECONCILE_QUEUE_MAX_SIZE=1000
MARKET_WS_ENABLED=false
EXECUTION_ENGINE_ENABLED=true
EXECUTION_INTERVAL_MS=3000
EXECUTION_MAX_ATTEMPTS_PER_RUN=25
EXECUTION_RETRY_BACKOFF_BASE_MS=5000
EXECUTION_RETRY_BACKOFF_MAX_MS=300000
DRY_RUN_MODE=false
TARGET_NETTING_ENABLED=true
TARGET_NETTING_INTERVAL_MS=5000
TARGET_NETTING_TRACKING_ERROR_BPS=0
MARKET_WATCH_TOKEN_IDS=
PANIC_MODE=false

# Reconcile + risk defaults
RECONCILE_INTERVAL_SECONDS=60
RECONCILE_ENGINE_ENABLED=true
RECONCILE_STALE_LEADER_SYNC_SECONDS=180
RECONCILE_STALE_FOLLOWER_SYNC_SECONDS=180
RECONCILE_GUARDRAIL_FAILURE_CYCLE_THRESHOLD=5
MARKET_CACHE_METADATA_TTL_MS=300000
MARKET_CACHE_WS_PRICE_TTL_MS=15000
MARKET_CACHE_REST_PRICE_TTL_MS=45000
MARKET_CACHE_REDIS_TTL_SECONDS=1800
LEADER_TRADES_POLL_INTERVAL_SECONDS=30
# Data API fallback filter for leader trades:
# true = only taker-side trades, false = include maker + taker (recommended)
LEADER_TRADES_TAKER_ONLY=false
LEADER_POLL_PAGE_LIMIT=100
LEADER_POLL_BATCH_SIZE=5
LEADER_POLL_MAX_RETRIES=5
LEADER_POLL_BACKOFF_BASE_MS=500
LEADER_POLL_BACKOFF_MAX_MS=15000
LEADER_POLL_MAX_PAGES_PER_LEADER=20
MIN_NOTIONAL_PER_ORDER_USD=1.00
MAX_WORSENING_BUY_USD=0.03
MAX_WORSENING_SELL_USD=0.06
MAX_SLIPPAGE_BPS=200
MAX_SPREAD_USD=0.03
# Optional buy-side cap; block buys above this price/share (blank = disabled)
MAX_PRICE_PER_SHARE_USD=
ATTEMPT_EXPIRATION_SECONDS=7200
COOLDOWN_PER_MARKET_SECONDS=5
MAX_EXPOSURE_PER_LEADER_USD=100
MAX_EXPOSURE_PER_MARKET_OUTCOME_USD=50
MAX_HOURLY_NOTIONAL_TURNOVER_USD=25
MAX_DAILY_NOTIONAL_TURNOVER_USD=100
MAX_RETRIES_PER_ATTEMPT=20

# Worker runtime
WORKER_HEALTH_PORT=4001
WORKER_HEARTBEAT_INTERVAL_MS=10000
WORKER_RUNTIME_CONFIG_REFRESH_INTERVAL_MS=5000
