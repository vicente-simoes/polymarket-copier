{
  "name": "@copybot/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"no lint config yet\"",
    "test": "node --import tsx --test test/**/*.test.ts",
    "backfill:leader-current-positions": "node --import tsx src/scripts/backfill-leader-current-positions.ts",
    "backfill:follower-current-positions": "node --import tsx src/scripts/backfill-follower-current-positions.ts",
    "backfill:leader-latest-trade-prices": "node --import tsx src/scripts/backfill-leader-latest-trade-prices.ts",
    "backfill:token-metadata": "node --import tsx src/scripts/backfill-token-metadata.ts",
    "fills:backfill": "node --import tsx src/scripts/fills-backfill.ts",
    "ledger:rebuild": "node --import tsx src/scripts/rebuild-leader-ledger.ts",
    "prune:history": "node --import tsx src/scripts/prune-history.ts"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.2.4",
    "@copybot/db": "workspace:*",
    "@copybot/shared": "workspace:*",
    "ethers": "5",
    "redis": "5.8.2",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
